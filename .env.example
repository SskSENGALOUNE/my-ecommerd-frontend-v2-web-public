# ───── Web Public / Storefront (Next.js) ─────
# Storefront dev server runs on port 5173 (matches auth-service FRONTEND_URL,
# used by the Google OAuth callback redirect).

# ───── Backend microservice base URLs ─────
# All services expose a global prefix `/api` with URI versioning `/v1`.
NEXT_PUBLIC_AUTH_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_PRODUCT_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_ORDER_API_URL=http://localhost:3002/api/v1
